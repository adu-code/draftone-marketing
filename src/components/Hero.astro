---
/**
 * Hero Component
 * First section of the landing page - emotionally resonant headline + CTA
 * Philosophy: Warm, patient, literary - speaks to "The Story Holder" who doubts their writing ability
 */
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container-text hero-content">
    <img src="/logo.png" alt="DraftOne" class="hero-logo" />
    <h1 id="hero-heading">The story you carry deserves to be written</h1>
    <p class="subheadline">
      DraftOne is an AI writing coach that helps first-time authors write their memoir by building their craft—not by writing it for them.
    </p>
    <a href="#waitlist" class="btn btn-primary btn-lg">Join Waitlist</a>
  </div>
</section>

<style>
  .hero {
    background-color: var(--bg-primary);
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    text-align: center;
  }

  .hero-content {
    padding-left: var(--space-4);
    padding-right: var(--space-4);
  }

  /* Desktop spacing - more generous vertical padding */
  @media (min-width: 768px) {
    .hero {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }

    .hero-content {
      padding-left: var(--space-6);
      padding-right: var(--space-6);
    }
  }

  /* Extra-large desktop - even more breathing room */
  @media (min-width: 1024px) {
    .hero {
      padding-top: 12.5rem;    /* 200px - Larger than --space-20 (160px), intentional for this section */
      padding-bottom: 12.5rem; /* 200px - Larger than --space-20 (160px), intentional for this section */
    }
  }

  .hero-logo {
    max-width: 400px;
    width: 100%;
    height: auto;
    margin: 0 auto var(--space-8);
    display: block;
  }

  @media (max-width: 767px) {
    .hero-logo {
      max-width: 280px;
      margin-bottom: var(--space-6);
    }
  }

  .hero h1 {
    margin-bottom: 0; /* Override default h1 margin */
  }

  .subheadline {
    margin-top: var(--space-3); /* 24px gap from headline */
    margin-bottom: var(--space-4); /* 32px gap to button */
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-primary);
    opacity: 0.9; /* Slightly muted for visual hierarchy */
    max-width: none; /* Override global paragraph max-width for full-width text */
  }

  /* Ensure button doesn't inherit paragraph styles */
  .hero .btn {
    margin-top: var(--space-4); /* Extra space before CTA */
  }

  /* Mobile: smaller gaps for tighter layout */
  @media (max-width: 767px) {
    .subheadline {
      margin-top: var(--space-3);
      margin-bottom: var(--space-3);
    }

    .hero .btn {
      margin-top: var(--space-3);
    }
  }
</style>

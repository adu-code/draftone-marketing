---
/**
 * HowItWorks Component
 * Explains the 3-step process from first memory to finished draft
 * Philosophy: Simple and approachable - makes the process feel manageable
 * Message: User maintains agency and authorship throughout
 */
---

<section class="how-it-works" aria-labelledby="howitworks-heading">
  <div class="container-text howitworks-content">
    <h2 id="howitworks-heading">From first memory to finished draft</h2>

    <div class="steps">
      <div class="step">
        <div class="step-number" aria-hidden="true">1</div>
        <div class="step-content">
          <h3 class="step-label">Start</h3>
          <p class="step-description">AI asks questions about your story</p>
        </div>
      </div>

      <div class="step">
        <div class="step-number" aria-hidden="true">2</div>
        <div class="step-content">
          <h3 class="step-label">Build</h3>
          <p class="step-description">You write, AI coaches your craft</p>
        </div>
      </div>

      <div class="step">
        <div class="step-number" aria-hidden="true">3</div>
        <div class="step-content">
          <h3 class="step-label">Finish</h3>
          <p class="step-description">Your manuscript, your voice, entirely yours</p>
        </div>
      </div>
    </div>

    <a href="#waitlist" class="btn btn-primary btn-lg">Join Waitlist</a>
  </div>
</section>

<style>
  .how-it-works {
    padding-top: var(--space-10);
    padding-bottom: var(--space-10);
    text-align: center;
  }

  .howitworks-content {
    padding-left: var(--space-4);
    padding-right: var(--space-4);
  }

  /* Desktop spacing - more generous vertical padding */
  @media (min-width: 768px) {
    .how-it-works {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }

    .howitworks-content {
      padding-left: var(--space-6);
      padding-right: var(--space-6);
    }
  }

  /* Extra-large desktop - consistent with other sections */
  @media (min-width: 1024px) {
    .how-it-works {
      padding-top: 9.375rem;    /* 150px - Consistent with Problem/Difference sections */
      padding-bottom: 9.375rem; /* 150px */
    }
  }

  .how-it-works h2 {
    margin-bottom: 0; /* Override default h2 margin */
  }

  /* Steps container */
  .steps {
    margin-top: var(--space-5); /* 40px gap from headline */
    margin-bottom: var(--space-5); /* 40px gap to CTA */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4); /* 32px between steps */
  }

  /* Individual step */
  .step {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-3); /* 24px gap between number and content */
    width: 100%;
    max-width: 500px;
  }

  /* Step number */
  .step-number {
    font-size: var(--text-3xl);
    font-family: var(--font-serif);
    font-weight: 600;
    color: var(--accent-primary);
    line-height: 1;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 2px solid var(--accent-primary);
  }

  /* Step content (label + description) */
  .step-content {
    flex: 1;
    text-align: left;
  }

  /* Step label: "Start", "Build", "Finish" */
  .step-label {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-1); /* 8px */
    line-height: 1.2;
  }

  /* Step description */
  .step-description {
    font-size: var(--text-base);
    color: var(--text-primary);
    opacity: 0.85;
    margin-bottom: 0;
    max-width: none; /* Override default paragraph max-width */
  }

  /* CTA button */
  .how-it-works .btn-primary {
    margin-top: 0; /* Controlled by .steps margin-bottom */
  }

  /* Desktop: larger text and spacing */
  @media (min-width: 768px) {
    .step-number {
      font-size: var(--text-4xl);
      width: 64px;
      height: 64px;
    }

    .step-label {
      font-size: var(--text-2xl);
    }

    .step-description {
      font-size: var(--text-lg);
    }

    .step {
      max-width: 600px;
    }
  }

  /* Mobile: center align for smaller screens */
  @media (max-width: 767px) {
    .step {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-2); /* Tighter gap for vertical stack */
    }

    .step-content {
      text-align: center;
    }

    .step-number {
      margin-bottom: var(--space-1);
    }

    .steps {
      gap: var(--space-5); /* More space between stacked items on mobile */
    }
  }

  /* Emphasize the final step to reinforce user authorship */
  .step:last-child .step-label {
    color: var(--accent-primary);
  }
</style>
